# Database (used by Docker Compose)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-to-a-strong-password
POSTGRES_DB=riffsync
DB_PORT=5433

# The full connection string (points to Docker Postgres on port 5433)
DATABASE_URL="postgresql://postgres:change-me-to-a-strong-password@localhost:5433/riffsync?schema=public"

# Auth
SESSION_SECRET="change-me-to-a-random-string"

# Storage (local or s3)
STORAGE_PROVIDER="local"
STORAGE_PATH="./storage"

# S3 (only needed if STORAGE_PROVIDER=s3)
# S3_ENDPOINT="https://your-r2-endpoint.r2.cloudflarestorage.com"
# S3_REGION="auto"
# S3_BUCKET="riffsync"
# S3_ACCESS_KEY_ID=""
# S3_SECRET_ACCESS_KEY=""

# Push Notifications (auto-generated by setup script — no action needed)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@localhost

# Email Notifications (optional — leave blank to disable email)
# Works with any SMTP provider: Gmail, Outlook, Fastmail, Resend, SendGrid, etc.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=RiffSync <noreply@example.com>
