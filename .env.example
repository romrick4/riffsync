# Database (Supabase Postgres)
# Pooled connection (Transaction mode) -- for app runtime
DATABASE_URL="postgresql://postgres.xxxx:password@aws-0-us-east-1.pooler.supabase.com:6543/postgres"
# Direct connection (bypasses pooler) -- for Prisma migrations
DIRECT_DATABASE_URL="postgresql://postgres.xxxx:password@aws-0-us-east-1.pooler.supabase.com:5432/postgres"

# Supabase Auth
NEXT_PUBLIC_SUPABASE_URL="https://xxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=""
SUPABASE_SECRET_KEY=""

# R2 Storage (Cloudflare)
S3_ENDPOINT="https://your-account-id.r2.cloudflarestorage.com"
S3_REGION="auto"
S3_BUCKET="riffsync"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""

# Push Notifications (auto-generated by setup script)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@localhost

# Email Notifications (Brevo SMTP)
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="RiffSync <noreply@riffsync.com>"

# Send emails for in-app notifications (new versions, comments, events, etc.)
# Set to "true" to enable. Disabled by default to control email volume/cost.
# Auth emails (verification codes) are always sent when SMTP is configured.
ENABLE_NOTIFICATION_EMAILS=false

# Fly.io Transcode Worker (wakes the machine when a new upload is confirmed)
FLY_WORKER_URL="https://riffsync-transcode.fly.dev"

# App URL (used for email links, password reset redirects)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
