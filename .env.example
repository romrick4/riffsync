# ──────────────────────────────────────────────
# RiffSync Configuration
# Copy this file to .env and fill in the values
# ──────────────────────────────────────────────

# Database (used by Docker Compose — change the password!)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-to-a-strong-password
POSTGRES_DB=riffsync

# The full connection string (auto-built by docker-compose, but needed for local dev)
DATABASE_URL="postgresql://postgres:change-me-to-a-strong-password@localhost:5432/riffsync?schema=public"

# Auth — generate a random string: openssl rand -base64 32
SESSION_SECRET=change-me-to-a-random-string

# App port (default 3000)
APP_PORT=3000

# Storage provider: "local" (default) or "s3"
STORAGE_PROVIDER=local
STORAGE_PATH=./storage

# S3-compatible storage (only needed if STORAGE_PROVIDER=s3)
# S3_ENDPOINT=https://your-endpoint.r2.cloudflarestorage.com
# S3_REGION=auto
# S3_BUCKET=riffsync
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
